// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma v7: connection URL is configured in prisma.config.ts
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  PHONE
}

enum PortfolioSnapshotSourceType {
  MANUAL
  CSV_IMPORT
  BROKER_SYNC
  OTHER
}

enum PortfolioAssetCategoryType {
  CASH
  EQUITY
  ETF
  CRYPTO
  FUND
  OTHER
}

enum ConnectedSourceKind {
  MANUAL_STATIC
  BANK
  BROKERAGE
  CRYPTO
}

enum ConnectedSourceStatus {
  ACTIVE
  NEEDS_ATTENTION
  DISCONNECTED
  ARCHIVED
}

enum ConnectedSyncTriggerType {
  MANUAL
  SCHEDULED
  WEBHOOK
  SYSTEM
}

enum ConnectedSyncStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL_SUCCESS
}

enum PortfolioSnapshotIngestionMode {
  MANUAL_STATIC
  CSV_IMPORT
  CONNECTED_SYNC
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identities             AuthIdentity[]
  refreshTokens          RefreshToken[]
  accounts               Account[]
  categories             Category[]
  subcategories          Subcategory[]
  transactions           Transaction[]
  importLogs             ImportLog[]
  connectedSources       ConnectedSourceRecord[]
  connectedSyncRuns      ConnectedSyncRunRecord[]
  manualStaticValuations ManualStaticValuationRecord[]
  portfolioSnapshots PortfolioSnapshotRecord[]
}

model AuthIdentity {
  id         String       @id @default(cuid())
  userId     String
  provider   AuthProvider
  identifier String
  secretHash String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, identifier])
  @@index([userId])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String
  parentTokenId     String?
  replacedByTokenId String?
  userAgent         String?
  ip                String?
  revokedAt         DateTime?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentToken       RefreshToken?  @relation("RefreshTokenParent", fields: [parentTokenId], references: [id])
  childTokens       RefreshToken[] @relation("RefreshTokenParent")
  replacedByToken   RefreshToken?  @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesTokens    RefreshToken[] @relation("RefreshTokenReplacement")

  @@index([userId])
  @@index([tokenHash])
  @@index([parentTokenId])
  @@index([replacedByTokenId])
  @@index([expiresAt])
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Category? @relation("CategoryToParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToParent")

  transactions  Transaction[]
  subcategories Subcategory[]

  @@unique([userId, name])
  @@index([userId])
  @@index([parentId])
}

model Subcategory {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, categoryId, name])
  @@index([userId])
  @@index([categoryId])
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  accountId   String
  type        TransactionType
  amountCents Int
  currency    String          @default("USD")
  occurredAt  DateTime
  merchant    String?
  note        String?
  categoryId  String?
  subcategoryId String?
  transferId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])
  category    Category?   @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([transferId])
}

model ImportLog {
  id          String   @id @default(cuid())
  userId      String
  kind        String
  contentHash String
  importedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, contentHash])
  @@index([userId, importedAt])
}

model ConnectedSourceRecord {
  id                   String                @id @default(cuid())
  userId               String
  kind                 ConnectedSourceKind
  providerKey          String?
  displayName          String
  status               ConnectedSourceStatus
  institutionName      String?
  baseCurrency         String                @default("USD")
  metadata             Json?
  lastSuccessfulSyncAt DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  user                   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts               ConnectedSourceAccountRecord[]
  syncRuns               ConnectedSyncRunRecord[]
  manualStaticValuations ManualStaticValuationRecord[]
  snapshots              PortfolioSnapshotRecord[]

  @@index([userId, createdAt])
  @@index([userId, kind])
  @@index([userId, status])
}

model ConnectedSourceAccountRecord {
  id                String   @id @default(cuid())
  sourceId          String
  externalAccountId String?
  displayName       String
  accountType       String
  currency          String   @default("USD")
  assetType         PortfolioAssetCategoryType?
  assetSubType      String?
  institutionOrIssuer String?
  maskLast4         String?
  isActive          Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  source                 ConnectedSourceRecord       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  manualStaticValuations ManualStaticValuationRecord[]

  @@index([sourceId, isActive])
  @@index([sourceId, createdAt])
}

model ManualStaticValuationRecord {
  id              String   @id @default(cuid())
  userId          String
  sourceId        String
  sourceAccountId String
  valuationDate   DateTime
  currency        String   @default("USD")
  marketValue     Decimal
  quantity        Decimal?
  unitPrice       Decimal?
  symbol          String?
  assetName       String?
  note            String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  source        ConnectedSourceRecord      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceAccount ConnectedSourceAccountRecord @relation(fields: [sourceAccountId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sourceId, valuationDate])
  @@index([sourceAccountId, valuationDate, createdAt])
}

model ConnectedSyncRunRecord {
  id                   String                   @id @default(cuid())
  userId               String
  sourceId             String
  triggerType          ConnectedSyncTriggerType
  status               ConnectedSyncStatus
  startedAt            DateTime?
  finishedAt           DateTime?
  errorCode            String?
  errorMessage         String?
  normalizationVersion String?
  rawPayloadRef        String?
  producedSnapshotId   String?                  @unique
  metadata             Json?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  source           ConnectedSourceRecord   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceSnapshots  PortfolioSnapshotRecord[] @relation("PortfolioSnapshotSourceSyncRun")
  producedSnapshot PortfolioSnapshotRecord?  @relation("ConnectedSyncRunProducedSnapshot", fields: [producedSnapshotId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sourceId, createdAt])
  @@index([sourceId, status])
}

model PortfolioSnapshotRecord {
  id                String                     @id @default(cuid())
  userId            String
  sourceId          String?
  sourceSyncRunId   String?
  ingestionMode     PortfolioSnapshotIngestionMode?
  normalizationVersion String?
  sourceFingerprint String?
  portfolioName     String?
  sourceType        PortfolioSnapshotSourceType?
  sourceLabel       String?
  snapshotDate      DateTime
  valuationCurrency String?
  totalValue        Decimal
  cashValue         Decimal?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source                ConnectedSourceRecord?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceSyncRun         ConnectedSyncRunRecord?  @relation("PortfolioSnapshotSourceSyncRun", fields: [sourceSyncRunId], references: [id], onDelete: SetNull)
  producedBySyncRun     ConnectedSyncRunRecord?  @relation("ConnectedSyncRunProducedSnapshot")
  positions             PortfolioPositionRecord[]
  reports               AIReportRecord[]
  financialHealthScores FinancialHealthScoreRecord[]

  @@index([userId, snapshotDate])
  @@index([sourceId])
  @@index([sourceSyncRunId])
  @@index([snapshotDate])
  @@index([createdAt])
}

model PortfolioPositionRecord {
  id              String                    @id @default(cuid())
  snapshotId      String
  assetKey        String
  symbol          String?
  name            String?
  quantity        Decimal?
  marketValue     Decimal
  portfolioWeight Decimal?
  costBasis       Decimal?
  pnlPercent      Decimal?
  category        PortfolioAssetCategoryType?
  /// Transitional linkage field for future ConnectedSourceAccountRecord FK backfill.
  sourceAccountId String?
  notes           String?

  snapshot PortfolioSnapshotRecord @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([assetKey])
  @@index([symbol])
}

model AIReportRecord {
  id               String   @id @default(cuid())
  reportType       String
  taskType         String
  sourceRunId      String
  sourceSnapshotId String?
  title            String
  contentMarkdown  String
  promptVersion    String
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceSnapshot PortfolioSnapshotRecord? @relation(fields: [sourceSnapshotId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([sourceRunId])
  @@index([sourceSnapshotId])
}

model FinancialHealthScoreRecord {
  id               String   @id @default(cuid())
  sourceSnapshotId String
  scoringVersion   String
  result           Json
  insight          Json
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceSnapshot PortfolioSnapshotRecord @relation(fields: [sourceSnapshotId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([sourceSnapshotId])
}
