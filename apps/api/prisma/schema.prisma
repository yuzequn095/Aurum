generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma v7: connection URL is configured in prisma.config.ts
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  PHONE
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identities    AuthIdentity[]
  refreshTokens RefreshToken[]
  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
}

model AuthIdentity {
  id         String       @id @default(cuid())
  userId     String
  provider   AuthProvider
  identifier String
  secretHash String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, identifier])
  @@index([userId])
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String
  parentTokenId     String?
  replacedByTokenId String?
  userAgent         String?
  ip                String?
  revokedAt         DateTime?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentToken       RefreshToken?  @relation("RefreshTokenParent", fields: [parentTokenId], references: [id])
  childTokens       RefreshToken[] @relation("RefreshTokenParent")
  replacedByToken   RefreshToken?  @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesTokens    RefreshToken[] @relation("RefreshTokenReplacement")

  @@index([userId])
  @@index([tokenHash])
  @@index([parentTokenId])
  @@index([replacedByTokenId])
  @@index([expiresAt])
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  parent   Category? @relation("CategoryToParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToParent")

  transactions Transaction[]

  @@index([userId])
  @@index([parentId])
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  accountId   String
  type        TransactionType
  amountCents Int
  currency    String          @default("USD")
  occurredAt  DateTime
  merchant    String?
  note        String?
  categoryId  String?
  transferId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  account  Account   @relation(fields: [accountId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([categoryId])
  @@index([transferId])
}
