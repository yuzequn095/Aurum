{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@aurum/core$": "<rootDir>/../../../packages/core/src/index.ts",
    "^@aurum/core/(.*)$": "<rootDir>/../../../packages/core/src/$1"
  }
}
